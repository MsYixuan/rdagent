BACKEND = rdagent.oai.backend.DeprecBackend
USE_AZURE=True
EMBEDDING_USE_AZURE_TOKEN_PROVIDER=True
CHAT_USE_AZURE_TOKEN_PROVIDER=True


EMBEDDING_AZURE_API_BASE=https://cloudgpt-openai.azure-api.net/openai/v1/
EMBEDDING_AZURE_API_VERSION=2025-04-01-preview
EMBEDDING_MODEL=text-embedding-3-small

OPENAI_API_BASE=https://cloudgpt-openai.azure-api.net/openai/v1/
CHAT_AZURE_API_VERSION=2025-04-01-preview
CHAT_MODEL=gpt-4o-20241120